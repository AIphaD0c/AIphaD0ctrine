:root {
  --bg: #0a0a0a;
  --panel: #111111;
  --edge: #242424;
  --text: #e8e8e8;
  --muted: #9a9a9a;
  --accent: #d8d8d8;
  --max: 1100px;
}

* { box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  margin: 0;
  background: linear-gradient(180deg, #070707 0%, #0b0b0b 100%);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Inter, Helvetica, Arial, sans-serif;
  line-height: 1.6;
}

a {
  color: var(--text);
  text-decoration: none;
  border-bottom: 1px solid #3a3a3a;
}

a:hover { border-bottom-color: #8a8a8a; }

.wrap {
  width: min(calc(100% - 2rem), var(--max));
  margin: 0 auto;
}

.site-header {
  padding: 4.5rem 0 2rem;
  border-bottom: 1px solid var(--edge);
  background:
    radial-gradient(circle at top right, rgba(255,255,255,0.06), transparent 24%),
    radial-gradient(circle at top left, rgba(255,255,255,0.03), transparent 18%);
}

.site-header.compact { padding-top: 3rem; }
.hero-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.95fr);
  gap: 2rem;
  align-items: center;
}
.hero-copy { min-width: 0; }
.hero-figure {
  margin: 0;
  border: 1px solid var(--edge);
  background: #050505;
  padding: 0.65rem;
}
.hero-image {
  display: block;
  width: 100%;
  height: auto;
  border: 0;
}
.hero-figure figcaption {
  color: var(--muted);
  font-size: 0.82rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  margin-top: 0.6rem;
}
.eyebrow {
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--muted);
  font-size: 0.78rem;
  margin: 0 0 0.75rem;
}

h1, h2, h3 { line-height: 1.15; margin: 0 0 0.75rem; }
h1 { font-size: clamp(2.4rem, 7vw, 4.8rem); font-weight: 800; letter-spacing: -0.03em; }
h2 { font-size: 1.2rem; text-transform: uppercase; letter-spacing: 0.08em; }
h3 { font-size: 1.1rem; }

.tagline {
  color: var(--accent);
  font-size: 1.15rem;
  margin: 0 0 0.35rem;
}
.signal-line {
  color: #bcbcbc;
  font-size: 0.98rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  margin: 0 0 1rem;
}
.lead { max-width: 48rem; color: #cfcfcf; }
.topnav {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  margin-top: 1.25rem;
}

main { padding: 2rem 0 4rem; }
.panel {
  background: rgba(17,17,17,0.95);
  border: 1px solid var(--edge);
  padding: 1.25rem 1.25rem 1rem;
  margin: 0 0 1rem;
}
.smalltext { color: #c7c7c7; }
.cards {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 1rem;
}
.card {
  border: 1px solid var(--edge);
  background: #0d0d0d;
  padding: 1rem;
}
.card.muted { opacity: 0.74; }
.card-kicker {
  font-size: 0.78rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--muted);
  margin: 0 0 0.35rem;
}
.tracklist {
  margin: 0;
  padding-left: 1.25rem;
}
.tracklist li { margin: 0.45rem 0; }
.meta-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 1rem;
  margin: 0;
}
.meta-grid dt {
  color: var(--muted);
  font-size: 0.82rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.meta-grid dd { margin: 0.35rem 0 0; }
.lyrics p { margin: 0 0 0.9rem; }

@media (max-width: 840px) {
  .hero-grid { grid-template-columns: 1fr; }
}

@media (max-width: 640px) {
  .site-header { padding-top: 3rem; }
  .panel { padding: 1rem; }
}
